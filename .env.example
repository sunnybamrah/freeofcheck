# FreeOfCheck environment variables (copy to .env for local dev; set real values
# in Railway -> Service -> Variables for production). The app runs WITHOUT any of
# these locally — they only raise limits / enable optional features.

# Strongly recommended in production. Raises the openFDA limit from 1,000/day per
# IP (keyless) to 120,000/day. Free: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# Set to "production" in prod (optional; the server serves static either way).
NODE_ENV=

# Max FDA labels fetched per drug (default 100). Each label doc is ~130KB.
OPENFDA_MAX_LABELS=

# Per-IP requests per minute on the proxy (default 30).
RATE_LIMIT=

# Set to "1" to pre-warm the cache for common OTC drugs at startup.
PREWARM=

# Optional fuzzy "did you mean" only — NEVER used for the Contains/Not-listed
# decision. Leave unset to disable (no spend).
LLM_API_KEY=
LLM_DAILY_CAP=
